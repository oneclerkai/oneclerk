modules = ["nodejs-20", "web", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["python_openai_ai_integrations:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "ffmpeg-full", "libiconv", "libxcrypt", "openssl", "pkg-config", "postgresql", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m uvicorn app.main:app --host 0.0.0.0 --port 5000 --timeout-keep-alive 60 --timeout-graceful-shutdown 120"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "5000"]

[userenv]

[userenv.shared]
ENVIRONMENT = "development"
JWT_ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = "1440"
ELEVENLABS_MODEL = "eleven_turbo_v2_5"
OPENAI_MODEL = "gpt-4o-mini"
USE_TELNYX_STT = "true"
FRONTEND_URL = "https://290b60f3-1c38-45c2-86d7-1dac9169ba37-00-y43lhseqjll9.sisko.replit.dev"
PUBLIC_BASE_URL = "https://290b60f3-1c38-45c2-86d7-1dac9169ba37-00-y43lhseqjll9.sisko.replit.dev"
BACKEND_URL = "https://290b60f3-1c38-45c2-86d7-1dac9169ba37-00-y43lhseqjll9.sisko.replit.dev"
