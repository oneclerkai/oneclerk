modules = ["nodejs-20", "web", "python-3.12"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "openssl", "pkg-config", "postgresql", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd oneclerk/frontend && npm run dev -- -p 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd oneclerk && uv run python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd oneclerk && uv run python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 & cd oneclerk/frontend && npm start -- -p 5000"]
build = ["bash", "-c", "cd oneclerk/frontend && npm install --legacy-peer-deps && npm run build"]

[userenv]

[userenv.shared]
ENVIRONMENT = "development"
JWT_SECRET_KEY = "replit-oneclerk-jwt-secret-key-2024"
OPENAI_MODEL = "gpt-4o-mini"
ELEVENLABS_MODEL = "eleven_turbo_v2_5"
NEXT_PUBLIC_API_URL = ""
NODE_ENV = "development"
