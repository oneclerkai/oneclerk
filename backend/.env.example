# Application
ENVIRONMENT=production
SECRET_KEY=generate-with-openssl-rand-base64-32
FRONTEND_URL=https://oneclerk.ai
PUBLIC_BASE_URL=https://api.oneclerk.ai
BACKEND_URL=https://api.oneclerk.ai

# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/oneclerk

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=generate-with-openssl-rand-base64-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Telnyx
