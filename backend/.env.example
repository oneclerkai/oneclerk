# Application
ENVIRONMENT=production
SECRET_KEY=generate-with-openssl-rand-base64-32
FRONTEND_URL=https://oneclerk.ai
PUBLIC_BASE_URL=https://api.oneclerk.ai
BACKEND_URL=https://api.oneclerk.ai

# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/oneclerk

# Redis
REDIS_URL=redis://default:password@host:6379/0

# JWT
JWT_SECRET_KEY=generate-with-openssl-rand-base64-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Telnyx (Telephony)
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=...
TELNYX_APP_ID=...
TELNYX_CONNECTION_ID=...

# Resend (Email OTP)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=OneClerk <verify@oneclerk.ai>

# Twilio (SMS OTP - Fallback)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# OpenAI (AI Brain)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=...
USE_TELNYX_STT=true
DEEPGRAM_FALLBACK_CONFIDENCE=0.7

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=...
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Voice IDs by language (ElevenLabs)
VOICE_EN_FEMALE=21m00Tcm4TlvDq8ikWAM
VOICE_EN_MALE=ErXwobaYiN019PkySvjV
VOICE_HI_FEMALE=pFZP5JQG7iQjIQuC4Bku
VOICE_AR_FEMALE=z9fAnlkpzviPz146aGWa
VOICE_ES_FEMALE=MF3mGyEYCl7XYWbV9V6O

# Google (OAuth & Calendar)
GOOGLE_CLIENT_ID=your-client-id-from-google-cloud.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-from-google-cloud
GOOGLE_REFRESH_TOKEN=your-refresh-token-obtained-from-oauth-flow

# Stripe (Billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...

# WhatsApp (Messaging via Telnyx)
WHATSAPP_API_URL=https://api.telnyx.com/v2/messages
WHATSAPP_FROM=+1...
